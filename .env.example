# Copy this file to `.env.local` for local development, or set the same vars in
# your Vercel project settings → Environment Variables for production.
#
# OPTIONAL — if you set this, every visitor to your deployment gets the
# "WhatsApp-style" Continue with Google button immediately, with no Client ID
# setup screen. Leave it unset to let each device paste its own Client ID.

VITE_GOOGLE_CLIENT_ID=
